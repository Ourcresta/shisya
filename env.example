# SHISHYA - Student Portal Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real secrets to version control

# ============================================
# DATABASE (Required)
# ============================================
# PostgreSQL connection string - automatically provided by Replit
DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================
# SESSION (Required)
# ============================================
# Random string for session encryption (generate with: openssl rand -hex 32)
SESSION_SECRET=your-random-session-secret-here

# ============================================
# EMAIL SERVICE (Required for OTP)
# ============================================
# Resend API key for sending verification emails
# Get yours at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ============================================
# AI INTEGRATION (Usha AI Tutor)
# ============================================
# Groq API key - PRIMARY LLM for Usha AI (llama-3.1-8b-instant)
# Get yours at: https://console.groq.com/keys
# If not set, falls back to OpenAI automatically
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Anthropic API key - MIDDLE TIER LLM for Usha AI (claude-haiku-4-5)
# Used as Tier 2 in cascade: Groq → Claude Haiku → OpenAI
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OpenAI API key - FALLBACK LLM for Usha AI (gpt-4o-mini) + Whisper STT + OpenAI TTS
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ============================================
# VIDEO STORAGE — Backblaze B2 (Primary)
# ============================================
# Backblaze B2 is used as the video/audio/subtitle storage backend.
# B2 is S3-compatible and ~60% cheaper than Cloudflare R2 ($6/TB vs $15/TB).
# B2 has zero egress fees to Cloudflare (Bandwidth Alliance partners).
#
# 1. Create a B2 bucket at https://www.backblaze.com/b2/cloud-storage.html
# 2. Create an application key with read/write access to that bucket
# 3. Note your endpoint URL (e.g. https://s3.us-west-004.backblazeb2.com)
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=your-bucket-name
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# ============================================
# VIDEO DELIVERY — Two-Phase CDN (Auto-switch)
# ============================================
# The platform automatically switches between two CDN tiers based on traffic:
#
# PHASE 1 — Cloudflare CDN (FREE):
#   B2 → Cloudflare CDN → students
#   Zero cost: B2 + Cloudflare are Bandwidth Alliance partners (no egress fees).
#   Set B2_CLOUDFLARE_URL to your Cloudflare CDN/Workers/R2-public hostname.
#   This is the default CDN when daily viewers < 100 and buffering rate < 5%.
#
# PHASE 2 — Bunny CDN (PERFORMANCE, auto-activated):
#   B2 → Bunny CDN → students
#   Better global edge presence for video streaming.
#   Activated automatically when:
#     - Unique video viewers today > 100, OR
#     - Buffering rate today > 5%
#   Set BUNNY_CDN_URL to your Bunny pull-zone hostname.
#
# AUTO-SWITCH: The server evaluates thresholds every hour and switches CDN
# mode automatically. GURU admin can also override via the CDN Status page.
#
# MIGRATION: When switching from Cloudflare R2 to B2, existing video URLs
# stored in the DB will still work as long as both CDN hostnames resolve.
# Use rclone to migrate files: rclone copy r2:bucket b2:bucket

# Phase 1 — Cloudflare CDN hostname (e.g. your Cloudflare custom domain or Workers URL)
B2_CLOUDFLARE_URL=https://videos.yourdomain.com

# Phase 2 — Bunny CDN pull-zone hostname (activated when thresholds are crossed)
BUNNY_CDN_URL=https://yourzone.b-cdn.net

# ============================================
# VIDEO STORAGE — Cloudflare R2 (Legacy Fallback)
# ============================================
# Only needed if you are still using Cloudflare R2 instead of B2.
# If both B2 and R2 credentials are set, B2 takes priority.
CLOUDFLARE_R2_ACCOUNT_ID=your-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET_NAME=your-r2-bucket-name
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ============================================
# OPTIONAL CONFIGURATION
# ============================================
# Node environment (development/production)
NODE_ENV=development

# Server port (default: 5000)
PORT=5000
